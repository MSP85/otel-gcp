package tests

import (
	"testing"

	"github.com/gruntwork-io/terratest/modules/k8s"
	"github.com/stretchr/testify/require"
)

func TestCollectorPodExists(t *testing.T) {
	options := k8s.NewKubectlOptions("", "", "your-namespace") // replace with your OpenShift namespace

	pods := k8s.ListPods(t, options, nil)
	require.Greater(t, len(pods), 0, "No pods found in the namespace")

	found := false
	for _, pod := range pods {
		if pod.Name == "otel-collector" || pod.Labels["app"] == "otel-collector" {
			found = true
			break
		}
	}
	require.True(t, found, "OpenTelemetry Collector pod not found")
}
