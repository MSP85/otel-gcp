package tests

import (
    "testing"
    "github.com/gruntwork-io/terratest/modules/k8s"
    metav1 "k8s.io/apimachinery/pkg/apis/meta/v1"
)

func TestCollectorPods(t *testing.T) {
    kubeOptions := k8s.NewKubectlOptions("", "", "my-namespace")

    pods, err := k8s.ListPodsE(t, kubeOptions, metav1.ListOptions{})
    if err != nil {
        t.Fatalf("Error listing pods: %v", err)
    }

    if len(pods.Items) == 0 {
        t.Fatalf("No pods found in namespace")
    }
}
